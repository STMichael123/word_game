LLM_API_KEY=your_openai_compatible_api_key_here
LLM_BASE_URL=https://api.openai-proxy.org/v1
LLM_MODEL=gpt-5.4

# Backward-compatible aliases still supported:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# NVIDIA_API_KEY=
# NVIDIA_BASE_URL=
# NVIDIA_MODEL=

# Optional: set true only if you want public sharing link
GRADIO_SHARE=false

# Optional knobs
STORY_SEED=42
MAX_HISTORY_EVENTS=20
TEMPERATURE=0.9
TOP_P=0.9
MAX_TOKENS=700
